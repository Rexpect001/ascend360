generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

enum TeamRole {
  TRUSTEE
  STAFF
  MENTOR
}

enum InquiryType {
  STUDENT
  VOLUNTEER
  PARTNER
  MEDIA
  OTHER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(EDITOR)
  name         String
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLogin    DateTime? @map("last_login")
  isActive     Boolean   @default(true) @map("is_active")

  posts BlogPost[]

  @@map("users")
}

model BlogPost {
  id            String     @id @default(uuid())
  title         String
  slug          String     @unique
  content       String     @db.Text
  excerpt       String?    @db.Text
  featuredImage String?    @map("featured_image")
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?  @map("published_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  authorId   String   @map("author_id")
  author     User     @relation(fields: [authorId], references: [id])
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  @@map("blog_posts")
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  posts BlogPost[]

  @@map("categories")
}

model Project {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  description     String        @db.Text
  longDescription String?       @map("long_description") @db.Text
  featuredImage   String?       @map("featured_image")
  heroImage       String?       @map("hero_image")
  status          ProjectStatus @default(ACTIVE)
  sdgAlignment    String?       @map("sdg_alignment")
  displayOrder    Int           @default(0) @map("display_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("projects")
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  title        String
  roleType     TeamRole @map("role_type")
  bio          String?  @db.Text
  imageUrl     String?  @map("image_url")
  linkedinUrl  String?  @map("linkedin_url")
  email        String?
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("team_members")
}

model ImpactStory {
  id           String    @id @default(uuid())
  studentName  String    @map("student_name")
  storyTitle   String    @map("story_title")
  storyContent String    @map("story_content") @db.Text
  imageUrl     String?   @map("image_url")
  outcome      String?
  isPublished  Boolean   @default(false) @map("is_published")
  createdAt    DateTime  @default(now()) @map("created_at")
  publishedAt  DateTime? @map("published_at")

  @@map("impact_stories")
}

model ContactSubmission {
  id          String      @id @default(uuid())
  name        String
  email       String
  message     String      @db.Text
  inquiryType InquiryType @map("inquiry_type")
  createdAt   DateTime    @default(now()) @map("created_at")
  readStatus  Boolean     @default(false) @map("read_status")
  notes       String?

  @@map("contact_submissions")
}

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  device    String?  // "mobile" | "tablet" | "desktop"
  createdAt DateTime @default(now()) @map("created_at")

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}
